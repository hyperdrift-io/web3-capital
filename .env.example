# ─────────────────────────────────────────────────────────────
# Capital Engine — environment variables
#
# Copy to .env.local for local development (gitignored).
# Set in your deployment platform (PM2 ecosystem / Ansible vault)
# for production.
#
# RPC strategy (driven by NODE_ENV):
#   development  → public CORS-friendly RPCs used as fallback
#                  Set vars below to override with a private key
#                  or an Anvil fork URL for local transaction testing.
#   production   → env vars below are used directly; falls back to
#                  the same public nodes if unset, but will rate-limit
#                  under real traffic — set private keys before launch.
# ─────────────────────────────────────────────────────────────

# ── RPC endpoints ─────────────────────────────────────────────
# Leave blank in development → public endpoints used automatically.
# Set to private Alchemy/Infura URLs before deploying to production.
#
# Alchemy:  https://eth-mainnet.g.alchemy.com/v2/<KEY>
# Infura:   https://mainnet.infura.io/v3/<KEY>
# Ankr:     https://rpc.ankr.com/eth/<KEY>
# Local Anvil fork: http://127.0.0.1:8545

NEXT_PUBLIC_RPC_MAINNET=
NEXT_PUBLIC_RPC_ARBITRUM=
NEXT_PUBLIC_RPC_BASE=
NEXT_PUBLIC_RPC_OPTIMISM=
NEXT_PUBLIC_RPC_POLYGON=

# ── Optional: Alchemy API key (used if RPC vars above are blank) ──
# If set, wagmi builds the full RPC URL automatically from this key.
# Covers all five chains. Takes priority over blank vars above.
NEXT_PUBLIC_ALCHEMY_KEY=
